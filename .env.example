# FYERS API Credentials (managed by shared/auth)
# Copy this file to .env and fill in your values

# Required for authentication
FYERS_CLIENT_ID=YOUR_APP_ID_HERE
FYERS_SECRET_KEY=YOUR_SECRET_KEY_HERE
FYERS_REDIRECT_URI=http://127.0.0.1:8080/

# Optional TLS overrides for corporate/self-signed certificate environments
# FYERS_INSECURE=1
# FYERS_CA_BUNDLE=/path/to/corporate-ca.pem

# Auto-populated after login
FYERS_ACCESS_TOKEN=

# Required for FYERS screener output in the dashboard
FYERS_WATCHLIST=NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:HDFCBANK-EQ,NSE:INFY-EQ,NSE:SBIN-EQ

# Optional frontend password gate for the ClawWork dashboard
VITE_APP_PASSWORD=your_dashboard_password_here

# ── Infrastructure (Kafka / PostgreSQL / Redis) ───────────────────────────────
# Set by infrastructure/docker-compose.yml — change only if using external services

# Redpanda (Kafka-compatible)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# PostgreSQL
CLAWWORKER_DB_USER=clawworker
CLAWWORKER_DB_PASSWORD=clawworker
CLAWWORKER_DB_NAME=clawworker
CLAWWORKER_DB_HOST=localhost
CLAWWORKER_DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
