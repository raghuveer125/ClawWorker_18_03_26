# FYERS API Credentials (managed by shared/auth)
# Copy this file to .env and fill in your values

# Required for authentication
FYERS_CLIENT_ID=YOUR_APP_ID_HERE
FYERS_SECRET_KEY=YOUR_SECRET_KEY_HERE
FYERS_REDIRECT_URI=http://127.0.0.1:8080/

# Optional TLS overrides for corporate/self-signed certificate environments
# FYERS_INSECURE=1
# FYERS_CA_BUNDLE=/path/to/corporate-ca.pem

# Auto-populated after login
FYERS_ACCESS_TOKEN=

# Required for FYERS screener output in the dashboard
FYERS_WATCHLIST=NSE:RELIANCE-EQ,NSE:TCS-EQ,NSE:HDFCBANK-EQ,NSE:INFY-EQ,NSE:SBIN-EQ
